# ===== Vault Obsidian =====
# WSL: se il vault si trova all'esterno del disco virtuale, il path dovrà 
#      iniziare con "/mnt/{DISK_LETTER}/..." dove DISK_LETTER è il disco di Windows.
VAULT_PATH=./vault

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=token_bot_telegram
TELEGRAM_ADMIN_CHAT_ID=chat_id

# ===== Web interface =====
# sezioni wiki esposte, separate da virgola
WEB_WIKI_ALLOWED_SECTIONS=wiki/public

# LLM — Download (usato da install.py per scaricare il modello da HuggingFace)
# Il modello viene salvato in data/models/{LLM_MODEL_REPO}/{LLM_MODEL_FILE}
# es. data/models/unsloth/Qwen3.5-9B-GGUF/Qwen3.5-9B-UD-Q3_K_XL.gguf
LLM_MODEL_REPO=unsloth/Qwen3.5-9B-GGUF
LLM_MODEL_FILE=Qwen3.5-9B-UD-Q3_K_XL.gguf

# ===== HuggingFace Authentication =====
# Token opzionale: velocizza il download e sblocca i modelli privati
# Ottienilo su https://huggingface.co/settings/tokens
HF_TOKEN=

# ===== Gestione automatica del server LLM =====
# Se true (default), llama-server viene avviato e fermato automaticamente con main.py
# Se false, gestisci llama-server manualmente (server esterno / inferenza remota)
#   — con LLM_MANAGED=false i modelli LLM non vengono scaricati da install.py
LLM_MANAGED=true


#--------------------------------------------------------------
# SE NON SAI COSA STAI FACENDO, NON TOCCARE DA QUI IN AVANTI :)
#--------------------------------------------------------------


# ===== Web interface - Advanced =====
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_SESSION_TTL_SECONDS=3600
WEB_CORS_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1,http://127.0.0.1:3000   # origini CORS permesse, separate da virgola

# ===== LLM — Client =====
# Endpoint per le richieste al modello
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL_NAME=local-model

# ===== LLM — Server =====
# Usato da llm_server_manager.py quando LLM_MANAGED=true
LLM_HOST=0.0.0.0
LLM_PORT=2360

# ===== LLM — Performance =====
# Usati da llm_server_manager.py quando LLM_MANAGED=true
LLM_N_GPU_LAYERS=-1        # -1 = tutti i layer sulle GPU (consigliato)

# blank = rilevato automaticamente dai metadati del modello; imposta un valore per limitare il contesto
LLM_N_CTX=                 

# true = split uguale automatico su tutte le GPU rilevate; false = GPU singola
LLM_MULTI_GPU=true         

# ===== Memoria conversazioni =====
CONVERSATIONS_DB_PATH=./data/conversations.db

# ===== Log =====
# Directory dove vengono salvati i log. Un file per ogni esecuzione: vesper_YYYY-MM-DD_HHMMSS.log
# Vengono mantenuti gli ultimi 10 file; i più vecchi vengono eliminati automaticamente.
LOG_DIR=./data/logs

# ===== RAG DB =====
CHROMA_PATH=./data/chroma

# ===== Embedding =====
# Modello sentence-transformers per il RAG.
# Attenzione: cambiare il modello invalida l'indice ChromaDB esistente.
EMBEDDING_MODEL=BAAI/bge-m3
CHUNK_SIZE=1024
CHUNK_OVERLAP=100

# ===== Vault Watcher =====
# Secondi di silenzio dopo l'ultimo salvataggio prima di re-indicizzare il file.
# Aumentare se Obsidian salva troppo frequentemente e causa re-indicizzazioni inutili.
VAULT_WATCH_DEBOUNCE_SECONDS=5

# ===== Re-ranker =====
# Cross-encoder che riordina i chunk RAG per rilevanza dopo il retrieval vettoriale.
# Con LLM_MANAGED=true gira come server separato su RERANKER_PORT (stesso binario llama-server).
# Abilitato di default. Impostare RERANKER_ENABLED=false per disabilitare completamente.
RERANKER_ENABLED=true

# Repo e file del modello GGUF su HuggingFace (usati da install.py per il download)
RERANKER_MODEL_REPO=Mungert/Qwen3-Reranker-4B-GGUF
RERANKER_MODEL_FILE=Qwen3-Reranker-4B-Q4_K_M.gguf

# Numero massimo di chunk da restituire dopo il reranking
RERANKER_TOP_K=5

# Porta del server re-ranker (usata quando LLM_MANAGED=true)
RERANKER_PORT=8001
